# Copiez ce fichier vers .env.local et renseignez vos identifiants.
# Toutes les variables sont publiques (préfixe NEXT_PUBLIC_) car utilisées côté client.
# Le site fonctionne même si certaines variables sont absentes (dégradation gracieuse).

# Formulaire de contact — identifiant Formspree (https://formspree.io)
NEXT_PUBLIC_FORMSPREE_ID=

# Microsoft Clarity — identifiant de projet (https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=

# Google Analytics 4 — Measurement ID (configuré via GTM)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager — Container ID
NEXT_PUBLIC_GTM_ID=

# URL de production (sans slash final) — utilisée pour le SEO/canonical/sitemap
NEXT_PUBLIC_SITE_URL=https://example.com

# Calendly — lien de réservation (optionnel : surcharge le lien par défaut du code)
NEXT_PUBLIC_CALENDLY_URL=
